{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FonaTech/E3-miu-GNN/raw/main/coupling/prediction_result.schema.json",
  "title": "E3-miu-GNN prediction result",
  "type": "object",
  "required": ["schema", "ok", "model", "structure", "units", "results", "components"],
  "properties": {
    "schema": {"const": "e3mu-prediction-v1"},
    "ok": {"const": true},
    "model": {
      "type": "object",
      "required": ["backend", "model_class", "mode", "device", "dtype", "configured_physics"],
      "properties": {
        "backend": {"const": "native_e3mu"},
        "model_class": {"type": "string"},
        "mode": {"enum": ["ground_only", "full_coupled"]},
        "requested_mode": {"enum": ["auto", "ground_only", "full_coupled"]},
        "device": {"enum": ["cpu", "mps", "cuda"]},
        "dtype": {"enum": ["float32", "float64"]},
        "configured_physics": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "structure": {
      "type": "object",
      "required": ["formula", "atom_count", "atomic_numbers", "positions_A", "cell_A", "pbc"],
      "properties": {
        "formula": {"type": "string"},
        "atom_count": {"type": "integer", "minimum": 1},
        "atomic_numbers": {"type": "array", "items": {"type": "integer", "minimum": 1, "maximum": 118}},
        "positions_A": {"type": "array", "items": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}], "items": false}},
        "cell_A": {"type": "array", "minItems": 3, "maxItems": 3},
        "pbc": {"type": "array", "prefixItems": [{"type": "boolean"}, {"type": "boolean"}, {"type": "boolean"}], "items": false}
      },
      "additionalProperties": false
    },
    "units": {"type": "object", "additionalProperties": {"type": "string"}},
    "results": {"type": "object", "minProperties": 1},
    "components": {"type": "object", "additionalProperties": {"type": "number"}}
  },
  "additionalProperties": false
}
